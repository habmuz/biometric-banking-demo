# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
CLAUDE_MODEL=claude-opus-4-6

# ── Token Server (Keycloak-compatible) ────────────────────────────────────────
KEYCLOAK_BASE_URL=http://token-server:8080
KEYCLOAK_REALM=biometric-banking
KEYCLOAK_CLIENT_ID=biometric-agent
KEYCLOAK_CLIENT_SECRET=change-this-in-production

# ── Liveness thresholds (ISO 30107-3 PAD Level 2) ─────────────────────────────
LIVENESS_THRESHOLD=0.50
DEEPFAKE_THRESHOLD=0.60
MAX_AUTH_ATTEMPTS=5

# ── InsightFace ────────────────────────────────────────────────────────────────
INSIGHTFACE_MODEL=buffalo_l
INSIGHTFACE_CTX_ID=-1   # -1 = CPU; 0 = first GPU

# ── Langfuse LLM observability (optional — leave blank to disable) ─────────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Misc ───────────────────────────────────────────────────────────────────────
AUDIT_LOG_PATH=audit.jsonl
HOST=0.0.0.0
PORT=8000

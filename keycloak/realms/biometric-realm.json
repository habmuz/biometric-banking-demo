{
  "realm": "biometric-banking",
  "displayName": "Biometric Banking",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 300,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,

  "roles": {
    "realm": [
      {
        "name": "banking_user",
        "description": "Standard authenticated banking user"
      },
      {
        "name": "banking_admin",
        "description": "Banking administrator"
      }
    ]
  },

  "clientScopes": [
    {
      "name": "login_api",
      "description": "Scope granting access to banking login-protected APIs",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "login_api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "portfolio-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "acr-claim",
      "description": "Authentication Context Class Reference claim",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "acr-hardcoded-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "acr",
            "claim.value": "3",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "access.tokenResponse.claim": "false"
          }
        }
      ]
    },
    {
      "name": "biometric-claims",
      "description": "Biometric authentication metadata claims",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "amr-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "amr",
            "claim.value": "face",
            "jsonType.label": "JSON",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "access.tokenResponse.claim": "false"
          }
        },
        {
          "name": "auth-method-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "auth_method",
            "claim.value": "biometric_face_liveness",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "access.tokenResponse.claim": "false"
          }
        }
      ]
    }
  ],

  "clients": [
    {
      "clientId": "biometric-agent",
      "name": "Biometric Authentication Agent",
      "description": "Server-side Claude agent that validates liveness and issues tokens",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "biometric-agent-secret-change-in-prod",
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "frontchannelLogout": false,
      "protocol": "openid-connect",
      "attributes": {
        "access.token.signed.response.alg": "RS256",
        "id.token.signed.response.alg": "RS256",
        "token.endpoint.auth.signing.alg": "RS256"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "acr-claim",
        "biometric-claims"
      ],
      "optionalClientScopes": [
        "login_api"
      ]
    },
    {
      "clientId": "portfolio-api",
      "name": "Portfolio API Resource Server",
      "description": "Banking portfolio API that accepts biometric JWTs",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "attributes": {
        "access.token.signed.response.alg": "RS256"
      }
    }
  ],

  "users": [
    {
      "username": "demo_user",
      "email": "demo@biometricbank.sg",
      "firstName": "Demo",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Demo@1234",
          "temporary": false
        }
      ],
      "realmRoles": ["banking_user"],
      "attributes": {
        "biometric_enrolled": ["true"],
        "biometric_template_id": ["demo_user_face_v1"],
        "pdpa_consent": ["true"],
        "pdpa_consent_date": ["2026-04-02"]
      }
    }
  ],

  "authenticationFlows": [
    {
      "alias": "biometric-direct-grant",
      "description": "Direct grant flow for biometric agent — agent pre-validates biometrics, calls token endpoint with service account",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "direct-grant-validate-username",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 10,
          "autheticatorFlow": false,
          "userSetupAllowed": false
        }
      ]
    }
  ],

  "browserSecurityHeaders": {
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';",
    "contentSecurityPolicyReportOnly": "",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains",
    "xContentTypeOptions": "nosniff",
    "xRobotsTag": "none",
    "xFrameOptions": "SAMEORIGIN",
    "xXSSProtection": "1; mode=block",
    "referrerPolicy": "no-referrer"
  },

  "smtpServer": {},
  "eventsEnabled": true,
  "eventsListeners": ["jboss-logging"],
  "enabledEventTypes": [
    "LOGIN",
    "LOGIN_ERROR",
    "LOGOUT",
    "TOKEN_EXCHANGE",
    "CLIENT_LOGIN",
    "CLIENT_LOGIN_ERROR"
  ],
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true,

  "internationalizationEnabled": false,
  "supportedLocales": ["en"],
  "defaultLocale": "en"
}
